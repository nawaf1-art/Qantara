# Qantara example environment.
# Copy to `.env` only if your shell/process manager loads env files.
# Do not commit real tokens, public URLs, or machine-specific paths.

# Gateway bind.
QANTARA_SPIKE_HOST=127.0.0.1
QANTARA_SPIKE_PORT=8765

# Optional LAN TLS. Generate local certs into ops/certs/ first.
# QANTARA_TLS_CERT=ops/certs/qantara-cert.pem
# QANTARA_TLS_KEY=ops/certs/qantara-key.pem

# Recommended backend path for local LLM engines that expose /v1/chat/completions.
QANTARA_ADAPTER=openai_compatible
QANTARA_OPENAI_BASE_URL=http://127.0.0.1:11434
QANTARA_OPENAI_MODEL=qwen2.5:3b
# QANTARA_OPENAI_API_KEY=not-needed

# Speech providers.
QANTARA_STT_PROVIDER=faster_whisper
QANTARA_TTS_PROVIDER=piper
QANTARA_WHISPER_MODEL=small

# Optional local auth for LAN deployments.
# Generate your own random 24+ character values before use.
# QANTARA_AUTH_TOKEN=replace-with-random-local-token-at-least-24-chars
# QANTARA_ADMIN_TOKEN=replace-with-different-random-local-token-at-least-24-chars

# Optional LAN mesh and Home Assistant Wyoming bridge.
# These bind to loopback by default. Use 0.0.0.0 only on a trusted LAN.
# QANTARA_MESH_ROLE=disabled
# QANTARA_MESH_HOST=127.0.0.1
# QANTARA_WYOMING_ENABLED=false
# QANTARA_WYOMING_HOST=127.0.0.1

# Optional advanced OpenClaw bridge.
# QANTARA_OPENCLAW_BIN=openclaw
# QANTARA_OPENCLAW_AGENT_ID=main
