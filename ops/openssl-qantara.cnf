[req]
default_bits = 2048
prompt = no
default_md = sha256
x509_extensions = v3_req
distinguished_name = dn

[dn]
C = KW
ST = Al Asimah
L = Kuwait City
O = Qantara
OU = Dev
CN = 192.168.68.59

[v3_req]
subjectAltName = @alt_names

[alt_names]
IP.1 = 127.0.0.1
IP.2 = 192.168.68.59
DNS.1 = localhost
DNS.2 = qantara.local
