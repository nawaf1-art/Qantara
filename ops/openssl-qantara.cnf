[req]
default_bits = 2048
prompt = no
default_md = sha256
x509_extensions = v3_req
distinguished_name = dn

[dn]
C = KW
ST = Example
L = Example City
O = Qantara
OU = Local Development
CN = qantara.local

[v3_req]
subjectAltName = @alt_names

[alt_names]
IP.1 = 127.0.0.1
IP.2 = 192.168.1.50
DNS.1 = localhost
DNS.2 = qantara.local
