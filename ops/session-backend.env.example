# Qantara real session backend example

# Keep the adapter generic. Point it at any backend that implements
# SESSION_GATEWAY_CONTRACT.md.

QANTARA_ADAPTER=session_gateway_http
QANTARA_BACKEND_BASE_URL=http://127.0.0.1:19110

# Optional:
# QANTARA_BACKEND_TOKEN=replace-me
# QANTARA_BACKEND_TIMEOUT=30

# Typical spike settings when running the browser path securely on LAN:
# QANTARA_TLS_CERT=ops/certs/qantara-cert.pem
# QANTARA_TLS_KEY=ops/certs/qantara-key.pem
# QANTARA_SPIKE_HOST=0.0.0.0
# QANTARA_SPIKE_PORT=9443
